
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the MentoIA Academy platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "User's full name."
        },
        "subscription": {
            "type": "object",
            "description": "User's subscription details.",
            "properties": {
                "plan": {
                    "type": "string",
                    "description": "The user's subscription plan.",
                    "enum": ["standard", "plus", "mentoria_plus_plus"]
                },
                "status": {
                    "type": "string",
                    "description": "The status of the subscription.",
                    "enum": ["active", "inactive", "canceled"]
                },
                "updatedAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Timestamp of the last subscription update."
                }
            },
            "required": ["plan", "status"]
        }
      },
      "required": ["id", "email", "name"]
    },
    "StudyTask": {
      "title": "Study Task",
      "type": "object",
      "description": "Represents a task in the user's weekly study plan.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "isCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "date", "isCompleted"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/users/{userId}/study_tasks/{taskId}",
        "definition": {
          "entityName": "StudyTask",
          "schema": { "$ref": "#/backend/entities/StudyTask" },
          "description": "User's private study plan tasks."
        }
      }
    ]
  }
}
