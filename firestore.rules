rules_version = '2';

function isSignedIn() {
  return request.auth != null;
}

function isOwner(userId) {
  return request.auth.uid == userId;
}

function getUserData() {
  return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
}

function isPlusSubscriber() {
  let userData = getUserData();
  return isSignedIn() && (userData.subscription.plan == 'plus' || userData.subscription.plan == 'mentoria_plus_plus' || userData.subscription.plan == 'academy');
}

function isAdmin() {
  return request.auth != null && (
    request.auth.token.email == 'amentoriaacademy@gmail.com' || 
    request.auth.token.email == 'mentorlite.admin@gmail.com'
  );
}

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /users/{userId}/study_tasks/{taskId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{document=**} {
      allow list: if isAdmin();
    }
    
    match /users/{userId}/{collection}/{docId} {
      allow read, write, list: if isOwner(userId) || isAdmin();
    }

    match /questoes/{questionId} {
      allow read: if resource.data.accessTier == 'standard' || isPlusSubscriber() || isAdmin() || resource.data.accessTier == null;
      allow list: if isSignedIn();
      allow write: if isAdmin(); 
    }
    
    match /questoes/{questionId}/comments/{commentId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /flashcards/{flashcardId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /communitySimulados/{simuladoId} {
       allow read, list: if isSignedIn();
       allow create: if isSignedIn();
       allow update: if isAdmin();
       allow delete: if isAdmin();
    }
    
    match /feed_posts/{postId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /previousExams/{examId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /studyTemplates/{templateId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}